<h1>📅 Timetable</h1>

<a href="/add">➕ Add</a> | 
<a href="/calendar">📆 Calendar</a> | 
<a href="/logout">🚪 Logout</a>

<table>
<tr>
<th>Subject</th><th>Day</th><th>Time</th><th>Actions</th>
</tr>

{% for row in data %}
<tr style="background-color: {{ row[4] }}">
    <td>{{ row[1] }}</td>
    <td>{{ row[2] }}</td>
    <td>{{ row[3] }}</td>
    <td>
        <a href="/edit/{{ row[0] }}">✏️ Edit</a>
        <a href="/delete/{{ row[0] }}">❌ Delete</a>
    </td>
</tr>
{% endfor %}
</table>
